# ── Supabase project credentials ────────────────────────────────────────────
# Create a free project at https://supabase.com
# Settings → API → copy the values below

# Exposed to the browser (Vite VITE_ prefix required)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Server-side only — NEVER commit or expose to the browser
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Sync server port (optional, defaults to 5000) ────────────────────────────
SERVER_PORT=5000

# ── Data source (no changes needed unless you fork openfootball) ─────────────
# Free, no API key, public domain, updates as matches finish
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
